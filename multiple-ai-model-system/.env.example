# ==================================================
# Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ==================================================

# Environment (development/production)
ENVIRONMENT=development
DEBUG=True

# Security - GENERATE A NEW KEY FOR PRODUCTION!
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=127.0.0.1,localhost

# Base URL
BASE_URL=http://localhost:8082

# Email Configuration
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=Your App <your_email@gmail.com>

# Redis / Celery
# Local: redis://127.0.0.1:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Database Configuration
# Use 'sqlite' for development, 'postgresql' for production
DATABASE_ENGINE=sqlite
DB_NAME=aimodel_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# CORS Configuration
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
WEBHOOK_SECRET_KEY=whsec_your_secret

# AI Services
FAL_KEY=your_fal_key
OPENAI_API_KEY=your_openai_key
GOOGLE_API_KEY=your_google_key

# ==================================================
# PRODUCTION CHECKLIST:
# 1. ENVIRONMENT=production
# 2. DEBUG=False
# 3. Generate new SECRET_KEY
# 4. Set actual ALLOWED_HOSTS
# 5. Use production Stripe keys
# ==================================================
